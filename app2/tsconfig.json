{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* JSX */
    "jsx": "react-jsx",
    "jsxImportSource": "react",

    /* Output */
    "outDir": "./dist",
    "rootDir": ".",
    "composite": true,

    /* Source Map */
    "sourceMap": true,

    /* Base URL */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@sg/geometry": ["../packages/geometry/src/index.ts"]
    }
  },
  "include": ["src", "test"],
  "exclude": ["node_modules"]
}
